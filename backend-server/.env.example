# RakshaSOS Backend Environment Template
# Update these values in your Render.com environment settings

PORT=3000
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"
JWT_SECRET="your_super_secret_production_key"

# Redis (Optional, for high-performance tracking)
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase (For notifications)
FIREBASE_PROJECT_ID=rakshasos-xxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
